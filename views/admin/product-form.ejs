<%- include('partials/sidebar', { pageTitle: product ? 'Edit Product' : 'New Product' }) %>

<div x-data="productForm()" x-init="init()">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800"><%= product ? 'Edit Product' : 'Add New Product' %></h1>
    <a href="/admin/products" class="text-sm text-gray-500 hover:text-gray-700">&larr; Back to Products</a>
  </div>

  <template x-if="error">
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-2 rounded-lg mb-4 text-sm" x-text="error"></div>
  </template>
  <template x-if="success">
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-2 rounded-lg mb-4 text-sm" x-text="success"></div>
  </template>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="font-semibold mb-4">Basic Info</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Product Name (Bengali) *</label>
            <input type="text" x-model="form.name" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Product Name (English)</label>
            <input type="text" x-model="form.nameEn" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
            <textarea x-model="form.description" rows="5" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500"></textarea>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="font-semibold mb-4">Images</h2>
        <div class="flex flex-wrap gap-3 mb-4">
          <template x-for="(img, i) in form.images" :key="i">
            <div class="relative w-24 h-24">
              <img :src="img" class="w-full h-full object-cover rounded-lg border">
              <button @click="form.images.splice(i, 1)" class="absolute -top-2 -right-2 bg-red-500 text-white w-5 h-5 rounded-full text-xs flex items-center justify-center">&times;</button>
            </div>
          </template>
        </div>
        <input type="file" accept="image/*" multiple @change="uploadImages($event)"
          class="text-sm text-gray-500 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-rose-50 file:text-rose-700 file:font-medium hover:file:bg-rose-100">
        <p class="text-xs text-gray-400 mt-1" x-show="uploading">Uploading...</p>
      </div>
    </div>

    <div class="space-y-6">
      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="font-semibold mb-4">Pricing</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Price (৳) *</label>
            <input type="number" x-model.number="form.price" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Discount Price (৳)</label>
            <input type="number" x-model.number="form.discountPrice" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500">
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="font-semibold mb-4">Organization</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
            <select x-model="form.category" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500">
              <option value="">No category</option>
              <% categories.forEach(function(cat) { %>
              <option value="<%= cat._id %>"><%= cat.name %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Product Code</label>
            <input type="text" x-model="form.productCode" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Stock</label>
            <input type="number" x-model.number="form.stock" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
            <select x-model="form.status" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500">
              <option value="active">Active</option>
              <option value="inactive">Inactive</option>
            </select>
          </div>
          <div class="flex items-center gap-4">
            <label class="flex items-center gap-2 text-sm">
              <input type="checkbox" x-model="form.isFlashSale" class="rounded text-rose-600"> Flash Sale
            </label>
            <label class="flex items-center gap-2 text-sm">
              <input type="checkbox" x-model="form.isFeatured" class="rounded text-rose-600"> Featured
            </label>
          </div>
        </div>
      </div>

      <button @click="save()" :disabled="saving"
        class="w-full bg-rose-600 hover:bg-rose-700 disabled:bg-gray-400 text-white py-2.5 rounded-xl font-semibold transition">
        <span x-show="!saving"><%= product ? 'Update Product' : 'Create Product' %></span>
        <span x-show="saving">Saving...</span>
      </button>
    </div>
  </div>
</div>

<script>
  const EDIT_PRODUCT = <%- product ? JSON.stringify(product) : 'null' %>;
</script>

<%- include('partials/end') %>
