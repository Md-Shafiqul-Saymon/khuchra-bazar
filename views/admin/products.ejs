<%- include('partials/sidebar', { pageTitle: 'Products' }) %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Products (<%= total %>)</h1>
  <a href="/admin/products/new" class="bg-rose-600 hover:bg-rose-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">+ Add Product</a>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <div class="p-4 border-b">
    <form action="/admin/products" method="GET" class="flex gap-2">
      <input type="text" name="search" value="<%= search || '' %>" placeholder="Search products..."
        class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500">
      <button type="submit" class="bg-gray-100 hover:bg-gray-200 px-4 py-2 rounded-lg text-sm transition">Search</button>
    </form>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-left">
        <tr>
          <th class="p-3 font-medium">Image</th>
          <th class="p-3 font-medium">Name</th>
          <th class="p-3 font-medium">Price</th>
          <th class="p-3 font-medium">Stock</th>
          <th class="p-3 font-medium">Status</th>
          <th class="p-3 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(function(product) { %>
        <tr class="border-t hover:bg-gray-50">
          <td class="p-3">
            <% if (product.images && product.images.length) { %>
            <img src="<%= product.images[0] %>" alt="" class="w-12 h-12 rounded-lg object-cover">
            <% } else { %>
            <div class="w-12 h-12 rounded-lg bg-gray-200 flex items-center justify-center text-gray-400 text-xs">N/A</div>
            <% } %>
          </td>
          <td class="p-3">
            <p class="font-medium line-clamp-1"><%= product.name %></p>
            <p class="text-xs text-gray-500"><%= product.slug %></p>
          </td>
          <td class="p-3">
            <% if (product.discountPrice) { %>
            <span class="text-rose-600 font-medium">৳<%= product.discountPrice %></span>
            <span class="text-gray-400 line-through text-xs ml-1">৳<%= product.price %></span>
            <% } else { %>
            <span class="font-medium">৳<%= product.price %></span>
            <% } %>
          </td>
          <td class="p-3"><%= product.stock %></td>
          <td class="p-3">
            <span class="px-2 py-0.5 rounded-full text-xs <%= product.status === 'active' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' %>"><%= product.status %></span>
            <% if (product.isFlashSale) { %><span class="px-2 py-0.5 rounded-full text-xs bg-amber-100 text-amber-700 ml-1">Flash</span><% } %>
          </td>
          <td class="p-3">
            <div class="flex gap-2">
              <a href="/admin/products/<%= product._id %>/edit" class="text-blue-600 hover:underline text-xs">Edit</a>
              <button onclick="deleteProduct('<%= product._id %>')" class="text-red-600 hover:underline text-xs">Delete</button>
            </div>
          </td>
        </tr>
        <% }); %>
        <% if (!products.length) { %>
        <tr><td colspan="6" class="p-8 text-center text-gray-400">No products found</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <% if (pages > 1) { %>
  <div class="flex justify-center gap-2 p-4 border-t">
    <% for (let i = 1; i <= pages; i++) { %>
    <a href="/admin/products?page=<%= i %><%= search ? '&search=' + search : '' %>"
      class="px-3 py-1 rounded-lg text-sm <%= i === page ? 'bg-rose-600 text-white' : 'bg-gray-100 hover:bg-gray-200' %>">
      <%= i %>
    </a>
    <% } %>
  </div>
  <% } %>
</div>

<%- include('partials/end') %>
