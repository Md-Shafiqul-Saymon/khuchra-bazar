<%- include('partials/sidebar', { pageTitle: 'Orders' }) %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Orders (<%= total %>)</h1>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <div class="p-4 border-b flex gap-2 flex-wrap">
    <a href="/admin/orders" class="px-3 py-1.5 rounded-lg text-sm transition <%= !statusFilter ? 'bg-rose-600 text-white' : 'bg-gray-100 hover:bg-gray-200' %>">All</a>
    <a href="/admin/orders?status=pending" class="px-3 py-1.5 rounded-lg text-sm transition <%= statusFilter === 'pending' ? 'bg-amber-600 text-white' : 'bg-gray-100 hover:bg-gray-200' %>">Pending</a>
    <a href="/admin/orders?status=confirmed" class="px-3 py-1.5 rounded-lg text-sm transition <%= statusFilter === 'confirmed' ? 'bg-blue-600 text-white' : 'bg-gray-100 hover:bg-gray-200' %>">Confirmed</a>
    <a href="/admin/orders?status=shipped" class="px-3 py-1.5 rounded-lg text-sm transition <%= statusFilter === 'shipped' ? 'bg-purple-600 text-white' : 'bg-gray-100 hover:bg-gray-200' %>">Shipped</a>
    <a href="/admin/orders?status=delivered" class="px-3 py-1.5 rounded-lg text-sm transition <%= statusFilter === 'delivered' ? 'bg-green-600 text-white' : 'bg-gray-100 hover:bg-gray-200' %>">Delivered</a>
    <a href="/admin/orders?status=cancelled" class="px-3 py-1.5 rounded-lg text-sm transition <%= statusFilter === 'cancelled' ? 'bg-red-600 text-white' : 'bg-gray-100 hover:bg-gray-200' %>">Cancelled</a>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-left">
        <tr>
          <th class="p-3 font-medium">Order #</th>
          <th class="p-3 font-medium">Customer</th>
          <th class="p-3 font-medium">Phone</th>
          <th class="p-3 font-medium">Total</th>
          <th class="p-3 font-medium">Status</th>
          <th class="p-3 font-medium">Date</th>
          <th class="p-3 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach(function(order) { %>
        <tr class="border-t hover:bg-gray-50">
          <td class="p-3 font-medium"><%= order.orderNumber %></td>
          <td class="p-3"><%= order.customerName %></td>
          <td class="p-3"><%= order.customerPhone %></td>
          <td class="p-3 font-medium">৳ <%= order.total %></td>
          <td class="p-3">
            <span class="px-2 py-0.5 rounded-full text-xs
              <%= order.status === 'pending' ? 'bg-amber-100 text-amber-700' : '' %>
              <%= order.status === 'confirmed' ? 'bg-blue-100 text-blue-700' : '' %>
              <%= order.status === 'shipped' ? 'bg-purple-100 text-purple-700' : '' %>
              <%= order.status === 'delivered' ? 'bg-green-100 text-green-700' : '' %>
              <%= order.status === 'cancelled' ? 'bg-red-100 text-red-700' : '' %>
            "><%= order.status %></span>
          </td>
          <td class="p-3 text-gray-500"><%= new Date(order.createdAt).toLocaleDateString('bn-BD') %></td>
          <td class="p-3">
            <a href="/admin/orders/<%= order._id %>" class="text-blue-600 hover:underline text-xs">View</a>
          </td>
        </tr>
        <% }); %>
        <% if (!orders.length) { %>
        <tr><td colspan="7" class="p-8 text-center text-gray-400">No orders found</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <% if (pages > 1) { %>
  <div class="flex justify-center gap-2 p-4 border-t">
    <% for (let i = 1; i <= pages; i++) { %>
    <a href="/admin/orders?page=<%= i %><%= statusFilter ? '&status=' + statusFilter : '' %>"
      class="px-3 py-1 rounded-lg text-sm <%= i === page ? 'bg-rose-600 text-white' : 'bg-gray-100 hover:bg-gray-200' %>"><%= i %></a>
    <% } %>
  </div>
  <% } %>
</div>

<%- include('partials/end') %>
