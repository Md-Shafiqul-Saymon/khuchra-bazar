<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - খুচরা বাজার</title>
  <link rel="stylesheet" href="/css/output.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>body { font-family: 'Inter', sans-serif; }</style>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center">
  <div class="w-full max-w-md px-4" x-data="{ username: '', password: '', error: '', loading: false }">
    <div class="bg-white rounded-2xl shadow-lg p-8">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-800">Admin Panel</h1>
        <p class="text-gray-500 mt-1">খুচরা বাজার</p>
      </div>

      <template x-if="error">
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-2 rounded-lg mb-4 text-sm" x-text="error"></div>
      </template>

      <form @submit.prevent="
        loading = true; error = '';
        fetch('/api/admin/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password })
        })
        .then(r => r.json())
        .then(data => {
          if (data.token) {
            document.cookie = 'admin_token=' + data.token + ';path=/;max-age=604800';
            window.location.href = '/admin';
          } else {
            error = data.message || 'Login failed';
          }
        })
        .catch(() => error = 'Connection error')
        .finally(() => loading = false)
      ">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
          <input type="text" x-model="username" required
            class="w-full border border-gray-300 rounded-xl px-4 py-2.5 focus:outline-none focus:border-rose-500 focus:ring-1 focus:ring-rose-500">
        </div>
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
          <input type="password" x-model="password" required
            class="w-full border border-gray-300 rounded-xl px-4 py-2.5 focus:outline-none focus:border-rose-500 focus:ring-1 focus:ring-rose-500">
        </div>
        <button type="submit" :disabled="loading"
          class="w-full bg-rose-600 hover:bg-rose-700 disabled:bg-gray-400 text-white py-2.5 rounded-xl font-semibold transition">
          <span x-show="!loading">Login</span>
          <span x-show="loading">Logging in...</span>
        </button>
      </form>
    </div>
  </div>
</body>
</html>
