<%- include('../partials/header') %>

<div class="max-w-4xl mx-auto px-4 py-6" x-data="cartPage()" x-init="loadCart()">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">আপনার কার্ট</h1>

  <template x-if="items.length === 0">
    <div class="text-center py-20 bg-white rounded-2xl shadow-sm">
      <svg class="w-20 h-20 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
      <p class="text-gray-500 text-lg mb-4">আপনার কার্ট খালি</p>
      <a href="/" class="inline-block bg-rose-600 text-white px-6 py-2.5 rounded-xl font-medium hover:bg-rose-700 transition">শপিং শুরু করুন</a>
    </div>
  </template>

  <template x-if="items.length > 0">
    <div>
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden mb-6">
        <template x-for="item in items" :key="item.productId">
          <div class="flex items-center gap-4 p-4 border-b last:border-b-0">
            <a :href="'/product/' + item.slug" class="w-20 h-20 rounded-lg overflow-hidden bg-gray-100 flex-shrink-0">
              <img :src="item.image || '/images/placeholder.svg'" :alt="item.name" class="w-full h-full object-cover">
            </a>
            <div class="flex-1 min-w-0">
              <a :href="'/product/' + item.slug" class="font-medium text-gray-800 line-clamp-2 hover:text-rose-600" x-text="item.name"></a>
              <div class="flex items-center gap-2 mt-1">
                <span class="text-rose-600 font-bold" x-text="'৳ ' + item.price"></span>
                <template x-if="item.originalPrice > item.price">
                  <span class="text-gray-400 text-sm line-through" x-text="'৳ ' + item.originalPrice"></span>
                </template>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <button @click="updateQty(item.productId, item.quantity - 1)"
                class="w-8 h-8 rounded-lg border flex items-center justify-center hover:bg-gray-100 transition">-</button>
              <span class="w-8 text-center font-medium" x-text="item.quantity"></span>
              <button @click="updateQty(item.productId, item.quantity + 1)"
                class="w-8 h-8 rounded-lg border flex items-center justify-center hover:bg-gray-100 transition">+</button>
            </div>
            <div class="text-right">
              <p class="font-bold text-gray-800" x-text="'৳ ' + item.lineTotal"></p>
              <button @click="removeItem(item.productId)" class="text-red-500 text-sm hover:underline mt-1">মুছুন</button>
            </div>
          </div>
        </template>
      </div>

      <div class="bg-white rounded-2xl shadow-sm p-6">
        <div class="flex justify-between items-center text-lg mb-4">
          <span class="font-medium">সাবটোটাল</span>
          <span class="font-bold text-rose-600" x-text="'৳ ' + subtotal"></span>
        </div>
        <p class="text-sm text-gray-500 mb-4">ডেলিভারি চার্জ চেকআউটে যোগ হবে</p>
        <a href="/checkout"
          class="block w-full bg-rose-600 hover:bg-rose-700 text-white text-center py-3 rounded-xl font-semibold transition text-lg">
          চেকআউট করুন
        </a>
      </div>
    </div>
  </template>
</div>

<%- include('../partials/footer') %>
