<%- include('../partials/header') %>

<div class="max-w-2xl mx-auto px-4 py-10">
  <div class="bg-white rounded-2xl shadow-sm p-8 text-center">
    <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
    </div>

    <h1 class="text-2xl font-bold text-gray-800 mb-2">অর্ডার সফল হয়েছে!</h1>
    <p class="text-gray-500 mb-6">আপনার অর্ডার গ্রহণ করা হয়েছে। শীঘ্রই আমরা আপনার সাথে যোগাযোগ করব।</p>

    <div class="bg-gray-50 rounded-xl p-6 text-left mb-6">
      <div class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <p class="text-gray-500">অর্ডার নম্বর</p>
          <p class="font-bold text-lg text-rose-600"><%= order.orderNumber %></p>
        </div>
        <div>
          <p class="text-gray-500">মোট</p>
          <p class="font-bold text-lg">৳ <%= order.total %></p>
        </div>
        <div>
          <p class="text-gray-500">নাম</p>
          <p class="font-medium"><%= order.customerName %></p>
        </div>
        <div>
          <p class="text-gray-500">মোবাইল</p>
          <p class="font-medium"><%= order.customerPhone %></p>
        </div>
        <div class="col-span-2">
          <p class="text-gray-500">ঠিকানা</p>
          <p class="font-medium"><%= order.customerAddress %></p>
        </div>
      </div>

      <div class="border-t mt-4 pt-4">
        <h3 class="font-semibold mb-2">অর্ডার আইটেম</h3>
        <% order.items.forEach(function(item) { %>
        <div class="flex justify-between text-sm py-1">
          <span><%= item.name %> x<%= item.quantity %></span>
          <span class="font-medium">৳ <%= item.price * item.quantity %></span>
        </div>
        <% }); %>
        <div class="flex justify-between text-sm py-1 border-t mt-2 pt-2">
          <span>ডেলিভারি চার্জ</span>
          <span class="font-medium">৳ <%= order.deliveryCharge %></span>
        </div>
      </div>
    </div>

    <a href="/" class="inline-block bg-rose-600 hover:bg-rose-700 text-white px-8 py-3 rounded-xl font-semibold transition">
      আরও শপিং করুন
    </a>
  </div>
</div>

<%- include('../partials/footer') %>
