{
  "name": "khuchra-bazar",
  "version": "1.0.0",
  "description": "খুচরা বাজার - E-commerce Website",
  "private": true,
  "scripts": {
    "build": "nest build",
    "vercel-build": "npm run tailwind:build && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "seed": "ts-node src/seed.ts",
    "tailwind:build": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./public/css/output.css --minify",
    "tailwind:watch": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./public/css/output.css --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mongoose": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/serve-static": "^5.0.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "ejs": "^3.1.10",
    "express": "^5.0.0",
    "mongoose": "^8.9.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@tailwindcss/cli": "^4.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "tailwindcss": "^4.0.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  }
}
