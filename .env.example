# MongoDB
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/DBNAME?appName=Cluster0

# Admin (change in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# JWT (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# AWS S3 (optional: if AWS_S3_BUCKET is empty, uploads go to public/uploads locally)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION=sa-east-1
AWS_S3_BUCKET=cdn-bucket-739860786211-sa-east-1-an
# Optional: custom public base — must be like https://BUCKET.s3.REGION.amazonaws.com (no path, or only a folder path).
# Wrong: bucket.REGION.s3.REGION.amazonaws.com — use virtual-hosted style: bucket.s3.REGION.amazonaws.com
# S3_BASE_URL=https://cdn-bucket-739860786211-sa-east-1-an.s3.sa-east-1.amazonaws.com
#
# Product images must be readable by the browser. Either:
# - Set AWS_S3_PUBLIC_READ=true (works if the bucket allows ACLs; PutObject uses public-read), OR
# - Keep this false and add an S3 bucket policy: s3:GetObject for Principal "*" on arn:...:bucket/uploads/*
#   (required if Object Ownership is "Bucket owner enforced" — ACLs are then ignored/disabled).

AWS_S3_PUBLIC_READ=true

# Presigned GET URLs for private buckets (seconds, max 604800 = 7 days). Used for storefront <img> tags.
# AWS_S3_SIGNED_URL_EXPIRES=604800

# Server (optional)
# PORT=3000
