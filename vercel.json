{
  "version": 2,
  "buildCommand": "npm run tailwind:build",
  "installCommand": "npm install",
  "functions": {
    "api/main.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "{views,public}/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/main" }
  ]
}
